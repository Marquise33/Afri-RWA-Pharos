{
  "name": "afrireal-protocol",
  "version": "1.0.0",
  "description": "AfriReal Protocol — African Real World Asset Marketplace on Pharos Network",
  "author": "Marquise (Moses Samuel Oluwagbemiga)",
  "license": "MIT",
  "scripts": {
    "compile":          "hardhat compile",
    "test":             "hardhat test",
    "test:coverage":    "hardhat coverage",
    "deploy:testnet":   "hardhat run scripts/deploy.js --network pharos_testnet",
    "deploy:mainnet":   "hardhat run scripts/deploy.js --network pharos_mainnet",
    "deploy:local":     "hardhat run scripts/deploy.js --network localhost",
    "node":             "hardhat node",
    "clean":            "hardhat clean",
    "gas-report":       "REPORT_GAS=true hardhat test",
    "lint":             "solhint 'contracts/**/*.sol'"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.22.0",
    "solhint": "^4.5.0",
    "dotenv": "^16.4.5"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2"
  }
}

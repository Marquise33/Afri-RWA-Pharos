# ─────────────────────────────────────────────────────────────
# AfriReal Protocol — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────────────────────

# Deployer wallet private key (no 0x prefix)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Pharos Network RPC endpoints
PHAROS_TESTNET_RPC=https://testnet.dplabs-internal.com
PHAROS_MAINNET_RPC=https://pharos-rpc.publicnode.com

# Block explorer API key (for contract verification)
ETHERSCAN_API_KEY=your_api_key_here

# CoinMarketCap API key (for gas reporting in USD)
CMC_API_KEY=your_cmc_key_here

# Deployed contract addresses (filled after deployment)
REGISTRY_ADDRESS=
MARKETPLACE_ADDRESS=
DEMO_TOKEN_ADDRESS=
